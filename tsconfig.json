{
    "compilerOptions": {
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "strictNullChecks": true,

        "outDir": "dist",
        "module": "commonjs",
        "moduleResolution": "node10",
        "target": "es2022",
        "isolatedModules": true,
        "declaration": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "ignoreDeprecations": "5.0,6.0"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules"
    ]
}